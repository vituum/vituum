{
  "name": "vituum",
  "version": "2.0.0-next.8",
  "type": "module",
  "main": "src/index.js",
  "types": "types/index.d.ts",
  "scripts": {
    "lint": "npm run eslint && npm run tsc",
    "tsc": "tsc",
    "eslint": "eslint '**/*.js'",
    "eslint-fix": "eslint '**/*.js' --fix",
    "publish-next": "npm publish --tag next"
  },
  "dependencies": {
    "chokidar": "^5.0",
    "picomatch": "^4.0",
    "vite": "^8.0.0-beta.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.39",
    "@stylistic/eslint-plugin": "^5.7",
    "@types/node": "^25",
    "eslint": "^9.39",
    "globals": "^17.0",
    "rolldown": "^1.0.0-beta.60",
    "typescript": "^5.9"
  },
  "files": [
    "src",
    "types"
  ],
  "exports": {
    ".": "./src/index.js",
    "./plugins/*": {
      "default": "./src/plugins/*",
      "types": "./types/plugins/*"
    },
    "./utils/*": {
      "default": "./src/utils/*",
      "types": "./types/utils/*"
    },
    "./types/*": {
      "types": "./types/*"
    },
    "./package.json": "./package.json"
  },
  "engines": {
    "node": "^24.0.0 || >=25.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vituum/vituum.git"
  }
}
