{
  "name": "vituum",
  "version": "2.0.0-next.5",
  "type": "module",
  "main": "src/index.js",
  "types": "types/index.d.ts",
  "scripts": {
    "tsc": "tsc",
    "eslint": "eslint '**/*.js'",
    "eslint-fix": "eslint '**/*.js' --fix",
    "publish-next": "npm publish --tag next"
  },
  "dependencies": {
    "chokidar": "^3.5",
    "fast-glob": "^3.3",
    "lodash": "^4.17",
    "minimatch": "^10.1",
    "vite": "^8.0.0-beta.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39",
    "@stylistic/eslint-plugin": "^5.6",
    "@types/node": "^25",
    "eslint": "^9.39",
    "globals": "^16.5.0",
    "rolldown": "^1.0.0-beta.55",
    "typescript": "^5.2"
  },
  "files": [
    "src",
    "types"
  ],
  "exports": {
    ".": "./src/index.js",
    "./plugins/*": {
      "default": "./src/plugins/*",
      "types": "./types/plugins/*"
    },
    "./utils/*": {
      "default": "./src/utils/*",
      "types": "./types/utils/*"
    },
    "./types/*": {
      "types": "./types/*"
    },
    "./package.json": "./package.json"
  },
  "engines": {
    "node": "^18.0.0 || >=20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vituum/vituum.git"
  }
}
